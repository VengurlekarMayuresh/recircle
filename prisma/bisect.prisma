generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

enum Role {
  individual
  business
  ngo
  volunteer
  transporter
  admin
}

enum Condition {
  new
  like_new
  good
  fair
  salvage
}

enum ListingType {
  donate
  sell
  exchange
}

enum MaterialStatus {
  available
  reserved
  claimed
  archived
  future
}

enum TransportMethod {
  self_pickup
  supplier_delivery
  platform_transporter
}

enum TransactionStatus {
  negotiating
  scheduled
  in_transit
  delivered
  confirmed
  cancelled
}

enum VehicleType {
  mini_truck
  pickup_van
  tempo
  autorickshaw
  bike
  other
}

enum TransporterStatus {
  available
  busy
  offline
}

enum BookingStatus {
  requested
  accepted
  pickup_scheduled
  collected
  in_transit
  delivered
  completed
  cancelled
}

enum Urgency {
  low
  medium
  high
}

enum WantStatus {
  open
  fulfilled
  expired
}

enum MatchStatus {
  pending
  accepted
  rejected
}

enum RouteRecommendation {
  reuse
  repair
  recycle
  dispose
}

enum UserLevel {
  seedling
  sprout
  sapling
  tree
  forest
}

enum VerificationLevel {
  unverified
  basic
  verified
  trusted
}

enum ReviewType {
  supplier_review
  receiver_review
  transporter_review
}

enum DisputeStatus {
  open
  reviewing
  resolved
}

enum AgentName {
  scout
  advisor
  quality
  sentinel
}

enum RepairHubType {
  workshop
  makerspace
  event
}

enum FraudStatus {
  pending
  reviewed
  cleared
  banned
}
